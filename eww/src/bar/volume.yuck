(defpoll bar_vol_icon    :interval "2s" :initial "󰕾" "bash ~/.config/eww/scripts/bar/volume.sh icon")
(defpoll bar_vol_color   :interval "2s" :initial "#cdd6f4" "bash ~/.config/eww/scripts/bar/volume.sh color")

(defwidget widget_volume []
  (box :orientation "horizontal"
       :spacing 4
       :halign "center"
       :valign "center"
       (label :class "bar-volume-icon"
              :style "color: ${bar_vol_color};"
              :text {bar_vol_icon})

  )
)
