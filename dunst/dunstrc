# dunst config

[global]
monitor = 0
follow = mouse

# Geometry
  width = 250
  height = (0, 300)
  origin = top-right
  offset = (20, 50)
  scale = 0
  gap_size = 10
  notification_limit = 8

# Progress bar
  progress_bar = true
  progress_bar_height = 10
  progress_bar_frame_width = 1
  progress_bar_min_width = 150
  progress_bar_max_width = 300
  progress_bar_corner_radius = 5
  progress_bar_corners = all

# Window
  transparency = 0
  separator_height = 2
  separator_color = frame
  padding = 8
  horizontal_padding = 8
  text_icon_padding = 15
  frame_width = 2
  frame_color = "#313244"
  corner_radius = 12
  corners = all

  indicate_hidden = yes
  sort = yes
  idle_threshold = 120

# Text
  font = Inter 10
  line_height = 2
  markup = full
  format = "<span size='large' weight='bold'>%s</span>\n%b"
  alignment = left
  vertical_alignment = top

  show_age_threshold = -1
  ellipsize = end
  word_wrap = yes
  ignore_newline = no

# Duplicates
  stack_duplicates = true
  hide_duplicate_count = false
  show_indicators = yes

# Regex
  enable_posix_regex = true

# Icons
  enable_recursive_icon_lookup = true
  icon_theme = "Tela-circle-dark"
  icon_position = left
  min_icon_size = 32
  max_icon_size = 32
  icon_corner_radius = 12
  icon_corners = all

# History
  sticky_history = yes
  history_length = 10

# Apps
  dmenu = /usr/bin/dmenu -p dunst:
  browser = /usr/bin/xdg-open

# Misc
  always_run_script = true
  title = Dunst
  class = Dunst
  ignore_dbusclose = false

# Wayland
  layer = top
  force_xwayland = false

# Legacy
  force_xinerama = false

# Mouse
  mouse_left_click = close_current
  mouse_middle_click = do_action, close_current
  mouse_right_click = close_all


  [experimental]
  per_monitor_dpi = false
  pause_on_mouse_over = true
  enable_pcre_regex = false


  [urgency_low]
  background = "#181825"
  foreground = "#cdd6f4"
  timeout = 10
  default_icon = dialog-information


  [urgency_normal]
  background = "#24283b"
  foreground = "#cdd6f4"
  frame_color = "#181825"
  timeout = 10
  override_pause_level = 30
  default_icon = dialog-information


  [urgency_critical]
  background = "#500c19eb"
  foreground = "#cdd6f4"
  frame_color = "#ff50648c"
  timeout = 0
  override_pause_level = 60
  default_icon = dialog-warning

### --- RULES --- ###
  [battery_low]
  summary = "Battery Low"
  body = ".*30%.*"
  msg_urgency = normal
  timeout = 10
  icon = /usr/share/icons/breeze/status/24/battery-caution-symbolic.svg

  [battery_critical]
  summary = "Battery Low"
  body = ".*15%.*"
  msg_urgency = critical
  timeout = 0
  icon = /usr/share/icons/breeze/status/24/battery-low-symbolic.svg
